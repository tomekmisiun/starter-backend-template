TEST_DATABASE_URL=postgresql://app_user:app_password@test_db:5432/app_test_db
DATABASE_URL=postgresql://app_user:app_password@db:5432/app_db
SECRET_KEY=replace-with-a-strong-random-secret-key
ENVIRONMENT=development
# Supported values: development, test, staging, production
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_SSL_CERT_REQS=required
REDIS_SOCKET_TIMEOUT_SECONDS=5
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=true
DB_POOL_TIMEOUT_SECONDS=30
DB_STATEMENT_TIMEOUT_MS=0
CORS_ENABLED=false
CORS_ALLOW_ORIGINS=
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*
TRUSTED_HOSTS_ENABLED=false
TRUSTED_HOSTS=
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=false
HSTS_MAX_AGE_SECONDS=31536000
LOG_LEVEL=INFO
# Supported values: text, json
LOG_FORMAT=text
RATE_LIMIT_DEFAULT_LIMIT=5
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
PASSWORD_RESET_RATE_LIMIT_LIMIT=3
PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_LOGIN_RATE_LIMIT_LIMIT=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_REGISTER_RATE_LIMIT_LIMIT=5
AUTH_REGISTER_RATE_LIMIT_WINDOW_SECONDS=300
# When true, rate limits use X-Forwarded-For / X-Real-IP (required in production).
RATE_LIMIT_TRUST_FORWARDED_HEADERS=false
# Supported values: public, disabled
REGISTRATION_POLICY=public
# Legacy unversioned routes (/auth/login, /users/, ...). Default: on in
# development/test/staging, off in production. Set explicitly to override.
# LEGACY_ROUTES_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com
PASSWORD_RESET_URL=http://localhost:8000/reset-password
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
WORKER_QUEUE_NAME=app_jobs
WORKER_FAILED_QUEUE_NAME=app_jobs_failed
WORKER_PROCESSING_QUEUE_NAME=app_jobs_processing
WORKER_DELAYED_QUEUE_NAME=app_jobs_delayed
WORKER_POLL_TIMEOUT_SECONDS=5
WORKER_MAX_RETRIES=3
WORKER_RETRY_BACKOFF_BASE_SECONDS=5
WORKER_RETRY_BACKOFF_MAX_SECONDS=300
WORKER_PROCESSING_VISIBILITY_TIMEOUT_SECONDS=300
WORKER_MAINTENANCE_ENABLED=true
WORKER_MAINTENANCE_INTERVAL_SECONDS=3600
WORKER_MAINTENANCE_LOCK_KEY=app_jobs_maintenance_lock
WORKER_MAINTENANCE_LOCK_TTL_SECONDS=300
WORKER_METRICS_ENABLED=true
WORKER_METRICS_HOST=0.0.0.0
WORKER_METRICS_PORT=9100
WORKER_QUEUE_MAINTENANCE_INTERVAL_SECONDS=5
WORKER_QUEUE_PROMOTE_BATCH_SIZE=100
USERS_CACHE_ENABLED=true
USERS_CACHE_TTL_SECONDS=60
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=uploads
S3_REGION_NAME=us-east-1
UPLOAD_MAX_SIZE_BYTES=5242880
UPLOAD_ALLOWED_CONTENT_TYPES=image/png,image/jpeg,application/pdf
UPLOAD_PRESIGNED_URL_EXPIRE_SECONDS=300
UPLOAD_MALWARE_SCAN_ENABLED=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_RELEASE=
PROMETHEUS_MULTIPROC_DIR=
METRICS_INSTANCE_ID=
# Production defaults METRICS_REQUIRE_AUTH=true; set a long random bearer token.
# METRICS_BEARER_TOKEN=
WEBHOOK_SIGNATURE_SECRET=
IDEMPOTENCY_TTL_SECONDS=86400
